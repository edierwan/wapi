# ──────────────────────────────────────────────────────────────
# WAPI — environment variables
# Copy this file to .env.local (for local dev) and fill in values.
# In Coolify, set these per environment (production / development).
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# Public app metadata (exposed to the browser, do NOT put secrets here)
NEXT_PUBLIC_APP_NAME=WAPI
# production:  https://wapi.getouch.co
# development: http://localhost:3000  (or your dev deployment URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# production | development | preview
NEXT_PUBLIC_APP_ENV=development

# PostgreSQL
# production DB name:  wapi
# development DB name: wapi.dev   (note the dot — valid in URL form)
# Example production:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/wapi
# Example development:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/wapi.dev
DATABASE_URL=

# ── Phase 2 (not used yet, placeholders) ──────────────────────

# Better Auth / session signing secret.
# The MVP bridge auth uses this (or BETTER_AUTH_SECRET) to sign session cookies.
# Generate: `openssl rand -hex 32`
SESSION_SECRET=

# Better Auth (Phase 2 proper auth)
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=

# Redis / BullMQ
# REDIS_URL=

# Tenant routing
# path (default)  — tenants live at /t/{slug}
# subdomain       — tenants live at {slug}.wapi.getouch.co  (requires wildcard SSL)
TENANT_ROUTING_MODE=path

# WhatsApp gateway (Baileys). The shared default used by tenants that don't
# configure their own gatewayUrl on connected_accounts.
# Example: https://wa.getouch.co
WA_GATEWAY_DEFAULT_URL=

# AI (Dify / Ollama)
# DIFY_DEFAULT_BASE_URL=
# DIFY_DEFAULT_API_KEY=
# OLLAMA_BASE_URL=
