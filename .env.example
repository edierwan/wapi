# ──────────────────────────────────────────────────────────────
# WAPI — environment variables
# Copy this file to .env.local (for local dev) and fill in values.
# In Coolify, set these per environment (production / development).
# ──────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# Public app metadata (exposed to the browser, do NOT put secrets here)
NEXT_PUBLIC_APP_NAME=WAPI
# production:  https://wapi.getouch.co
# development: http://localhost:3000  (or your dev deployment URL)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# production | development | preview
NEXT_PUBLIC_APP_ENV=development

# PostgreSQL
# production DB name:  wapi
# development DB name: wapi.dev   (note the dot — valid in URL form)
# Example production:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/wapi
# Example development:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/wapi.dev
DATABASE_URL=

# ── Phase 2 (not used yet, placeholders) ──────────────────────

# Better Auth
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=

# Redis / BullMQ
# REDIS_URL=

# WhatsApp / Baileys (Phase 2+, lives in a separate worker)
# WAPI_SESSION_STORAGE_PATH=

# AI (Dify / Ollama)
# DIFY_API_URL=
# DIFY_API_KEY=
# OLLAMA_BASE_URL=
